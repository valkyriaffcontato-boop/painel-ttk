<!DOCTYPE html>
<html>
<head>
    <title>Painel Loja FF</title>
    <style>
        body { font-family: sans-serif; background: #1a1a1a; color: white; padding: 20px; }
        .card { background: #2a2a2a; padding: 20px; border-radius: 10px; margin-bottom: 20px; }
        input { padding: 10px; margin: 5px; width: 300px; }
        button { padding: 10px 20px; background: orange; border: none; cursor: pointer; font-weight: bold; }
        .produto { border-bottom: 1px solid #444; padding: 10px 0; }
    </style>
</head>
<body>
    <h1>⚙️ Painel de Configuração - Bot FF</h1>
    <form action="/salvar" method="POST">
        <div class="card">
            <h3>Configurações Gerais</h3>
            ID Categoria Ticket: <input type="text" name="categoriaId" value="<%= config.categoriaId %>"><br>
            ID Cargo Suporte: <input type="text" name="cargoId" value="<%= config.cargoId %>"><br>
            Chave PIX: <input type="text" name="pix" value="<%= config.pix %>">
        </div>

        <div class="card">
            <h3>Adicionar Produtos</h3>
            <div id="lista-produtos">
                <% config.produtos.forEach(p => { %>
                    <div class="produto">
                        Nome: <input type="text" name="nome_p" value="<%= p.label %>"> 
                        Preço: <input type="text" name="preco_p" value="<%= p.price %>">
                    </div>
                <% }) %>
            </div>
            <button type="button" onclick="add()">+ Adicionar Linha</button>
        </div>

        <button type="submit" style="background: green; color: white;">SALVAR TUDO</button>
    </form>

    <script>
        function add() {
            const div = document.createElement('div');
            div.className = 'produto';
            div.innerHTML = 'Nome: <input type="text" name="nome_p"> Preço: <input type="text" name="preco_p">';
            document.getElementById('lista-produtos').appendChild(div);
        }
    </script>
</body>
</html>
